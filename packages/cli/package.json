{
  "name": "@specferret/cli",
  "version": "0.1.1",
  "description": "SpecFerret keeps your specs honest.",
  "type": "module",
  "bin": {
    "ferret": "./dist/bin/ferret.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun ../../scripts/clean-dist.ts dist && tsc --project tsconfig.build.json",
    "bundle": "bun build bin/ferret.ts --bundle --target=bun --outfile=dist/ferret.bundle.js --external bun:sqlite --external node:fs --external node:path --external node:crypto --external node:process --external node:os",
    "test": "bun test"
  },
  "dependencies": {
    "@specferret/core": "0.1.1",
    "commander": "^14.0.3",
    "glob": "^13.0.6",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "typescript": "^6.0.2"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BenGardiner123/spec-ferret.git"
  },
  "homepage": "https://specferret.dev"
}
